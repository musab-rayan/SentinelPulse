@model SentinelPulse.Models.FIRModel
@{ ViewData["Title"] = "Register FIR"; }

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />

<div class="page-header">
    <div>
        <h1 class="page-title">First Information Report</h1>
        <p class="page-sub">File a new FIR — 3 step wizard</p>
    </div>
</div>

<div class="glass-card wizard-card">
    <div class="wizard-progress">
        <div class="progress-bar-track"><div id="progress-fill" class="progress-bar-fill" style="width:33%"></div></div>
        <div class="wizard-steps">
            <div class="step active" data-step="1"><span>1</span> Citizen Details</div>
            <div class="step" data-step="2"><span>2</span> Crime Details</div>
            <div class="step" data-step="3"><span>3</span> Location</div>
        </div>
    </div>

    <form asp-action="Create" method="post" id="fir-form">
        @Html.AntiForgeryToken()

        @* Hidden coordinate fields — submitted with the form, populated by map click *@
        <input type="hidden" name="Latitude"  id="lat-input" />
        <input type="hidden" name="Longitude" id="lng-input" />

        <div class="wizard-step" data-step="1">
            <div class="form-row">
                <div class="form-group">
                    <label>Citizen Name</label>
                    <input asp-for="CitizenName" class="form-control-warm" />
                    <span asp-validation-for="CitizenName" class="field-error"></span>
                </div>
                <div class="form-group">
                    <label>CNIC</label>
                    <input asp-for="CitizenCNIC" class="form-control-warm" placeholder="00000-0000000-0" />
                </div>
            </div>
            <div class="form-group">
                <label>Phone Number</label>
                <input asp-for="PhoneNumber" class="form-control-warm" placeholder="+92-300-0000000" />
            </div>
        </div>

        <div class="wizard-step hidden" data-step="2">
            <div class="form-group">
                <label>Crime Type</label>
                <select asp-for="CrimeType" class="form-control-warm">
                    <option value="">Select...</option>
                    <option>Theft</option>
                    <option>Assault</option>
                    <option>Burglary</option>
                    <option>Cybercrime</option>
                    <option>Vandalism</option>
                    <option>Fraud</option>
                    <option>Murder</option>
                    <option>Kidnapping</option>
                    <option>Armed Robbery</option>
                    <option>Domestic Violence</option>
                    <option>Drug Offence</option>
                    <option>Terrorism</option>
                    <option>Noise Complaint</option>
                    <option>Trespassing</option>
                    <option>Other</option>
                </select>
            </div>
            <div class="form-group">
                <label>Description</label>
                <textarea asp-for="Description" class="form-control-warm" rows="5"></textarea>
            </div>
        </div>

        <div class="wizard-step hidden" data-step="3">
            <div class="form-row">
                <div class="form-group">
                    <label>Location</label>
                    <input asp-for="Location" class="form-control-warm" />
                </div>
                <div class="form-group">
                    <label>District</label>
                    <input asp-for="District" class="form-control-warm" />
                </div>
            </div>

            <div style="margin-top:16px;">
                <label style="color:var(--muted);font-size:0.85rem;text-transform:uppercase;letter-spacing:1px;">
                    Click on map to mark exact crime location (optional)
                </label>
                <div id="firMap" style="height:300px;border-radius:12px;margin-top:8px;border:1px solid var(--border);"></div>
                <div id="coords-display" class="text-muted-warm" style="margin-top:6px;font-size:0.85rem;"></div>
            </div>
        </div>

        <div class="wizard-actions">
            <button type="button" class="btn-ghost" id="prev-btn" disabled><i class="bi bi-arrow-left"></i> Previous</button>
            <button type="button" class="btn-primary-amber" id="next-btn">Next <i class="bi bi-arrow-right"></i></button>
            <button type="submit" class="btn-primary-amber hidden" id="submit-btn"><i class="bi bi-check2"></i> Submit FIR</button>
        </div>
    </form>
</div>

@if (ViewBag.CNICWarning != null)
{
    <div class="alert alert-warning" style="margin-top:1rem">@ViewBag.CNICWarning</div>
}

@section Scripts {
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
    initWizard();

    var firMap = null;
    var marker = null;

    function initFIRMap() {
        if (firMap) return;
        var mapDiv = document.getElementById('firMap');
        if (!mapDiv) return;

        firMap = L.map('firMap').setView([33.6844, 73.0479], 12);
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            attribution: '&copy; OpenStreetMap contributors'
        }).addTo(firMap);

        firMap.on('click', function(e) {
            var lat = e.latlng.lat.toFixed(6);
            var lng = e.latlng.lng.toFixed(6);

            document.getElementById('lat-input').value = lat;
            document.getElementById('lng-input').value = lng;
            document.getElementById('coords-display').textContent = 'Marked: ' + lat + ', ' + lng;

            if (marker) {
                marker.setLatLng(e.latlng);
            } else {
                marker = L.marker(e.latlng, { draggable: true }).addTo(firMap);
                marker.on('dragend', function(ev) {
                    var pos = ev.target.getLatLng();
                    document.getElementById('lat-input').value = pos.lat.toFixed(6);
                    document.getElementById('lng-input').value = pos.lng.toFixed(6);
                    document.getElementById('coords-display').textContent =
                        'Marked: ' + pos.lat.toFixed(6) + ', ' + pos.lng.toFixed(6);
                });
            }
        });
    }

    // Initialize map when Step 3 becomes visible
    document.getElementById('next-btn').addEventListener('click', function() {
        setTimeout(function() {
            var step3 = document.querySelector('[data-step="3"]');
            if (step3 && !step3.classList.contains('hidden')) {
                setTimeout(initFIRMap, 200);
            }
        }, 100);
    });
</script>
}

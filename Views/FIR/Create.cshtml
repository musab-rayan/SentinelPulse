@model SentinelPulse.Models.FIRModel
@{ ViewData["Title"] = "Register FIR"; }

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />

<div class="page-header">
    <div>
        <h1 class="page-title">First Information Report</h1>
    </div>
</div>

<div class="glass-card wizard-card">
    <div class="wizard-progress">
        <div class="progress-bar-track"><div id="progress-fill" class="progress-bar-fill" style="width:33%"></div></div>
        <div class="wizard-steps">
            <div class="step active" data-step="1"><span>1</span> Citizen Details</div>
            <div class="step" data-step="2"><span>2</span> Crime Details</div>
            <div class="step" data-step="3"><span>3</span> Location</div>
        </div>
    </div>

    <form asp-action="Create" method="post" id="fir-form">
        @Html.AntiForgeryToken()

        @if (ViewBag.CNICWarning != null)
        {
            <div style="background:var(--danger-soft);color:var(--danger);padding:12px 16px;border-radius:10px;border:1px solid rgba(214,36,42,0.25);margin-bottom:16px;">
                <i class="bi bi-exclamation-triangle-fill"></i> @ViewBag.CNICWarning
            </div>
        }
        @if (ViewBag.AllowForce == true)
        {
            <input type="hidden" name="forceSubmit" value="true" />
        }

        @* Hidden coordinate fields — submitted with the form, populated by map click *@
        <input type="hidden" name="Latitude"  id="lat-input" />
        <input type="hidden" name="Longitude" id="lng-input" />

        <div class="wizard-step" data-step="1">
            <div class="form-row">
                <div class="form-group">
                    <label>Citizen Name</label>
                    <input asp-for="CitizenName" class="form-control-warm" required />
                    <span asp-validation-for="CitizenName" class="field-error"></span>
                </div>
                <div class="form-group">
                    <label>CNIC</label>
                    <input asp-for="CitizenCNIC" class="form-control-warm" placeholder="1234567890123" required />
                    <span asp-validation-for="CitizenCNIC" class="field-error"></span>
                </div>
            </div>
            <div class="form-group">
                <label>Phone Number</label>
                <input asp-for="PhoneNumber" class="form-control-warm" placeholder="03001234567" required />
                <span asp-validation-for="PhoneNumber" class="field-error"></span>
            </div>
        </div>

        <div class="wizard-step hidden" data-step="2">
            <div class="form-group">
                <label>Crime Type</label>
                <select asp-for="CrimeType" class="form-control-warm" required>
                    <option value="">Select...</option>
                    <option>Theft</option>
                    <option>Assault</option>
                    <option>Burglary</option>
                    <option>Cybercrime</option>
                    <option>Vandalism</option>
                    <option>Fraud</option>
                    <option>Murder</option>
                    <option>Kidnapping</option>
                    <option>Armed Robbery</option>
                    <option>Domestic Violence</option>
                    <option>Drug Offence</option>
                    <option>Terrorism</option>
                    <option>Noise Complaint</option>
                    <option>Trespassing</option>
                    <option>Missing Person</option>
                    <option>Other</option>
                </select>
            </div>
            <div class="form-group">
                <label>Description</label>
                <textarea asp-for="Description" class="form-control-warm" rows="5" required></textarea>
            </div>
        </div>

        <div class="wizard-step hidden" data-step="3">
            <div class="form-row">
                <div class="form-group">
                    <label>Location</label>
                    <input asp-for="Location" class="form-control-warm" />
                </div>
                <input type="hidden" asp-for="District" value="Islamabad" />
            </div>

            <div style="margin-top:16px;">
                @await Html.PartialAsync("_LocationPicker", new ViewDataDictionary(ViewData) {
                    { "MapId", "firMap" },
                    { "MapLabel", "Click on map to mark exact crime location (optional)" }
                })
            </div>
        </div>

        <div class="wizard-actions">
            <button type="button" class="btn-ghost" id="prev-btn" disabled><i class="bi bi-arrow-left"></i> Previous</button>
            <button type="button" class="btn-primary-amber" id="next-btn">Next <i class="bi bi-arrow-right"></i></button>
            <button type="submit" class="btn-primary-amber hidden" id="submit-btn"><i class="bi bi-check2"></i> Submit FIR</button>
        </div>
    </form>
</div>

@section Scripts {
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script src="~/js/location-picker.js" asp-append-version="true"></script>
<script>
    initWizard();

    // Initialise the reusable location picker for Step 3
    var firPicker = initLocationPicker({
        mapId:           'firMap',
        latInputId:      'lat-input',
        lngInputId:      'lng-input',
        addressInputId:  'Location',   // asp-for="Location" renders id="Location"
        coordsDisplayId: 'firMap-coords'
    });

    // Ensure map renders correctly when Step 3 becomes visible
    document.getElementById('next-btn').addEventListener('click', function () {
        setTimeout(function () {
            var step3 = document.querySelector('[data-step="3"]');
            if (step3 && !step3.classList.contains('hidden')) {
                firPicker.init();
                setTimeout(function () { firPicker.invalidateSize(); }, 300);
            }
        }, 100);
    });
</script>
}

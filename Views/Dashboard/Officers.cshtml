@model List<SentinelPulse.Models.OfficerModel>
@{ ViewData["Title"] = "Officer Management"; }

<div class="page-header">
    <div>
        <h1 class="page-title">Officer Management</h1>
        <p class="page-sub">Station Personnel</p>
    </div>
</div>

<div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:1rem;">
    @foreach (var o in Model)
    {
        var activeCases = ViewData[$"cases_{o.Id}"] as int? ?? 0;
        var statusColor = o.Status == "Active" ? "var(--success)" : "var(--text-secondary)";
        var statusBg = o.Status == "Active" ? "var(--success-soft)" : "var(--surface-2)";
        var statusBorder = o.Status == "Active" ? "var(--success-soft-border)" : "var(--border)";
        <div class="glass-card" style="display:flex;flex-direction:column;gap:.75rem;">
            <div style="display:flex;align-items:center;gap:1rem;">
                <div class="officer-avatar" style="width:52px;height:52px;font-size:1.3rem;flex-shrink:0;">
                    @(o.Name.Length > 0 ? o.Name[0].ToString().ToUpper() : "?")
                </div>
                <div style="flex:1;min-width:0;">
                    <div style="font-weight:700;font-size:1rem;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">@o.Name</div>
                    <div style="font-size:.8rem;color:var(--muted);"><span class="badge-num">@o.BadgeNumber</span> · @o.Role</div>
                </div>
                <span style="display:inline-block;padding:.2rem .65rem;border-radius:10px;font-size:.72rem;font-weight:600;text-transform:uppercase;background:@statusBg;border:1px solid @statusBorder;color:@statusColor;white-space:nowrap;">
                    @(o.Status ?? "Active")
                </span>
            </div>
            <div class="kv"><label>Email</label><div style="font-size:.85rem;overflow:hidden;text-overflow:ellipsis;">@o.Email</div></div>
            <div class="kv"><label>Active Cases</label><div><span class="badge-num">@activeCases</span></div></div>
            <div style="margin-top:.5rem;">
                <a href="/Dashboard/OfficerDetails/@o.Id" class="btn-primary-amber" style="width:auto;padding:.5rem 1.2rem;font-size:.85rem;">
                    <i class="bi bi-person-lines-fill"></i> View Profile
                </a>
            </div>
        </div>
    }
</div>

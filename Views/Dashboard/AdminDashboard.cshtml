@model SentinelPulse.Models.DashboardViewModel
@{ ViewData["Title"] = "Admin Dashboard"; }

<div class="page-header">
    <div>
        <h1 class="page-title">DSP Command Dashboard</h1>
        <p class="page-sub">Station-wide overview</p>
    </div>
</div>

<div class="stats-grid">
    <div class="glass-card stat-card" onclick="location.href='/Cases/Index'">
        <div class="stat-icon amber"><i class="bi bi-folder2-open"></i></div>
        <div class="stat-label">Active Cases</div>
        <div class="stat-value counter" data-target="@Model.ActiveCases">0</div>
    </div>
    <div class="glass-card stat-card" onclick="location.href='/Cases/Index#pending-approval'">
        <div class="stat-icon blue"><i class="bi bi-hourglass-split"></i></div>
        <div class="stat-label">Pending Approval</div>
        <div class="stat-value counter" data-target="@Model.PendingFIRs">0</div>
    </div>
    <div class="glass-card stat-card" onclick="location.href='/Dashboard/Officers'">
        <div class="stat-icon green"><i class="bi bi-people-fill"></i></div>
        <div class="stat-label">Total Officers</div>
        <div class="stat-value counter" data-target="@Model.TotalOfficers">0</div>
    </div>
    <div class="glass-card stat-card" onclick="location.href='/Cases/Index?status=Closed'">
        <div class="stat-icon red"><i class="bi bi-check2-circle"></i></div>
        <div class="stat-label">Closed Cases</div>
        <div class="stat-value counter" data-target="@Model.ClosedCases">0</div>
    </div>
</div>

@{
    var zainabAlerts = ViewBag.ActiveZainabAlerts as List<SentinelPulse.Models.MissingChildModel>;
}
@if (zainabAlerts != null && zainabAlerts.Any())
{
    <div class="glass-card" style="padding:20px;margin-bottom:24px;border-left:3px solid var(--danger);">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:14px;">
            <div>
                <h3 style="margin:0;color:var(--danger);"><i class="bi bi-exclamation-triangle-fill"></i> Active Zainab Alerts</h3>
                <span class="text-muted-warm">@zainabAlerts.Count active missing child @(zainabAlerts.Count == 1 ? "alert" : "alerts")</span>
            </div>
            <a href="/Dashboard/ZainabAlert" class="link-amber">View All →</a>
        </div>
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:12px;">
            @foreach (var alert in zainabAlerts)
            {
                <a href="/Dashboard/ZainabAlertDetails/@alert.AlertId" style="text-decoration:none;color:inherit;">
                    <div class="glass-card" style="padding:14px;border-radius:10px;transition:transform 0.2s, box-shadow 0.2s;background:var(--nbg);box-shadow:var(--raise);" onmouseover="this.style.boxShadow='var(--inset)';" onmouseout="this.style.boxShadow='var(--raise)';">
                        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:6px;">
                            <span class="badge-num">ZA-@alert.AlertId.ToString("D3")</span>
                            <div style="display:flex;gap:4px;align-items:center;">
                                @if (!string.IsNullOrEmpty(alert.PendingStatus))
                                {
                                    <span class="status-badge pending-approval">PENDING APPROVAL</span>
                                }
                                <span class="status-badge emergency">@alert.Status</span>
                            </div>
                        </div>
                        <div style="display:flex;gap:12px;align-items:center;margin-bottom:8px;">
                            @if (!string.IsNullOrEmpty(alert.PhotoPath))
                            {
                                <img src="@alert.PhotoPath" alt="@alert.ChildName" style="width:48px;height:48px;border-radius:50%;object-fit:cover;box-shadow:var(--inset);" />
                            }
                            else
                            {
                                <div style="width:48px;height:48px;border-radius:50%;background:var(--txt);display:grid;place-items:center;font-weight:bold;color:var(--nbg);box-shadow:var(--inset);">
                                    @(alert.ChildName.Substring(0,1).ToUpper())
                                </div>
                            }
                            <div>
                                <div style="font-weight:600;font-size:0.95rem;">@alert.ChildName</div>
                                <div class="text-muted-warm" style="font-size:0.8rem;">Age @alert.Age · @alert.Gender</div>
                            </div>
                        </div>
                        <div class="text-muted-warm" style="font-size:0.8rem;margin-bottom:4px;">@alert.LastSeenLocation</div>
                        <div class="text-muted-warm" style="font-size:0.72rem;">@alert.ReportedDate.ToString("dd MMM HH:mm")</div>
                    </div>
                </a>
            }
        </div>
    </div>
}

<div class="dash-grid">
    <div class="glass-card chart-card">
        <div class="card-header-row">
            <h3>Crime Distribution</h3>
            <span class="text-muted-warm">Last 30 days</span>
        </div>
        <canvas id="crimeChart" height="120"></canvas>
    </div>

    <div class="glass-card table-card">
        <div class="card-header-row">
            <h3>Recent FIRs</h3>
            <a asp-controller="FIR" asp-action="Create" class="link-amber">+ New FIR</a>
        </div>
        <div class="table-responsive">
            <table class="data-table">
                <thead>
                    <tr><th>Case ID</th><th>Citizen</th><th>Crime</th><th>District</th><th>Status</th></tr>
                </thead>
                <tbody>
                @foreach (var fir in Model.RecentFIRs)
                {
                    <tr>
                        <td><span class="badge-num">@fir.CaseId</span></td>
                        <td>@fir.CitizenName</td>
                        <td>@fir.CrimeType</td>
                        <td>@fir.District</td>
                        <td><span class="status-badge @fir.Status.ToLower()">@fir.Status</span></td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
<script>
    const crimeData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.CrimeDistribution));
    initCrimeChart(crimeData);
    initCounters();
</script>
}

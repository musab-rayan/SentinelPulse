@model SentinelPulse.Models.LoginViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sign In — SentinelPulse</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.2/font/bootstrap-icons.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="login-body">
    <div class="login-bg">
        <div class="login-card-wrap">
            <div class="login-brand">
                <div class="brand-logo-login"><i class="bi bi-shield-fill-check"></i></div>
                <div class="login-title">SentinelPulse</div>
                <div class="login-subtitle">Law Enforcement Operations Portal</div>
            </div>

            <form method="post" asp-action="Login" class="login-form">
                @Html.AntiForgeryToken()
                @if (ViewBag.Error != null)
                {
                    <div class="login-error">
                        <i class="bi bi-exclamation-circle-fill"></i> @ViewBag.Error
                    </div>
                }
                <div class="login-field">
                    <label>Badge Number</label>
                    <input type="text" name="Username" required autofocus placeholder="e.g. SP-1042" />
                </div>
                <div class="login-field">
                    <label>Password</label>
                    <input type="password" name="Password" required placeholder="Enter password" />
                </div>
                <button type="submit" class="login-btn">
                    Sign In <i class="bi bi-arrow-right"></i>
                </button>
            </form>

            <div class="login-footer">
                <i class="bi bi-lock-fill"></i> Secure access for authorized personnel only
            </div>
        </div>
    </div>
    <script src="~/js/particle-bg.js" asp-append-version="true"></script>
</body>
</html>

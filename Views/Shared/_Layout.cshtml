<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SentinelPulse</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.2/font/bootstrap-icons.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
@if (!string.IsNullOrEmpty(Context.Session.GetString("OfficerName")))
{
    <nav class="top-nav">
        <div class="nav-container">
            <a href="/Dashboard/Index" class="nav-brand">
                <div class="brand-logo-sm"><i class="bi bi-shield-fill-check"></i></div>
                <span class="brand-text">SentinelPulse</span>
            </a>

            <div class="nav-links">
                <a href="/Dashboard/Index" class="nav-link">Dashboard</a>
                <a href="/FIR/Index" class="nav-link">FIR</a>
                <a href="/Cases/Index" class="nav-link">Cases</a>
                <a href="/Dashboard/ZainabAlert" class="nav-link nav-link-danger">Zainab Alert</a>
                <a href="/Dashboard/CrimeMap" class="nav-link">Crime Map</a>
                @if (Context.Session.GetString("OfficerRole") == "Admin")
                {
                    <a href="/Dashboard/Officers" class="nav-link">Officers</a>
                }
            </div>

            <div class="nav-right">
                <span class="clock-small" id="live-clock"></span>
                <button id="alert-bell" class="icon-btn alert-btn" type="button" title="Broadcast Emergency"><i class="bi bi-bell-fill"></i></button>
                <button id="theme-toggle" class="icon-btn" type="button" title="Toggle theme"><i class="bi bi-moon-stars-fill"></i></button>
                <div class="officer-chip-top">
                    <div class="officer-avatar-sm">@Context.Session.GetString("OfficerName")?[0]</div>
                    <div class="officer-info-sm">
                        <div class="officer-name-sm">@Context.Session.GetString("OfficerName")</div>
                        <div class="officer-meta-sm">@Context.Session.GetString("OfficerBadge") · @Context.Session.GetString("OfficerRole")</div>
                    </div>
                    <a href="/Account/Logout" class="logout-btn" title="Logout"><i class="bi bi-box-arrow-right"></i></a>
                </div>
            </div>
        </div>
    </nav>

    <div id="emergency-banner" class="emergency-banner">
        <i class="bi bi-exclamation-triangle-fill"></i>
        <span id="banner-text"></span>
        <button class="banner-close" type="button" onclick="document.getElementById('emergency-banner').classList.remove('show')">×</button>
    </div>

    <main class="main-content">
        @RenderBody()
    </main>
}
else
{
    @RenderBody()
}

<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
@await RenderSectionAsync("PrintArea", required: false)
</body>
</html>

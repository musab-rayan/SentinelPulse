<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SentinelPulse</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.2/font/bootstrap-icons.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
@{
    var officerName = Context.Session.GetString("OfficerName");
    var officerBadge = Context.Session.GetString("OfficerBadge");
    var officerRole = Context.Session.GetString("OfficerRole");
    var isLoggedIn = !string.IsNullOrEmpty(officerName);
}

@if (isLoggedIn)
{
    <div id="emergency-banner" class="emergency-banner">
        <i class="bi bi-exclamation-triangle-fill"></i>
        <span id="banner-text">No active alerts</span>
        <button class="banner-close" onclick="document.getElementById('emergency-banner').classList.remove('show')">&times;</button>
    </div>

    <div class="app-shell">
        <aside class="sidebar" id="sidebar">
            <div class="brand">
                <div class="brand-logo"><i class="bi bi-shield-shaded"></i></div>
                <div>
                    <div class="brand-name">SentinelPulse</div>
                    <div class="brand-sub">Law Enforcement Portal</div>
                </div>
            </div>
            <nav class="nav-list">
                <a asp-controller="Dashboard" asp-action="Index" class="nav-item"><i class="bi bi-speedometer2"></i> Dashboard</a>
                <a asp-controller="FIR" asp-action="Index" class="nav-item"><i class="bi bi-file-earmark-plus"></i> FIR Registration</a>
                <a asp-controller="Cases" asp-action="Index" class="nav-item"><i class="bi bi-folder2-open"></i> Cases</a>
                @if (Context.Session.GetString("OfficerRole") == "Admin")
                {
                    <a class="nav-item" href="/Dashboard/Officers"><i class="bi bi-people"></i> Officers</a>
                    <a class="nav-item" href="/Dashboard/CrimeMap"><i class="bi bi-geo-alt"></i> Crime Map</a>
                }
            </nav>
            <div class="sidebar-footer">
                <a asp-controller="Account" asp-action="Logout" class="nav-item"><i class="bi bi-box-arrow-right"></i> Logout</a>
            </div>
        </aside>

        <div class="main-area">
            <header class="topbar">
                <button class="icon-btn d-md-none" id="sidebar-toggle"><i class="bi bi-list"></i></button>
                <div class="clock" id="live-clock">--:--:--</div>
                <div class="topbar-right">
                    <button class="icon-btn alert-btn" id="alert-bell" title="Broadcast Emergency"><i class="bi bi-bell-fill"></i></button>
                    <button class="icon-btn" id="theme-toggle" title="Toggle theme"><i class="bi bi-moon-stars-fill"></i></button>
                    <div class="officer-chip">
                        <div class="officer-avatar">@(officerName?[0])</div>
                        <div class="officer-info">
                            <div class="officer-name">@officerName</div>
                            <div class="officer-meta"><span class="badge-num">@officerBadge</span> · @officerRole</div>
                        </div>
                    </div>
                </div>
            </header>

            <main class="content">
                @RenderBody()
            </main>
        </div>
    </div>
}
else
{
    @RenderBody()
}

<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>

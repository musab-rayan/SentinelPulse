@model SentinelPulse.Models.CaseModel
@{ ViewData["Title"] = $"Case {Model.CaseId}"; }

<div class="page-header">
    <div>
        <h1 class="page-title">@Model.Title</h1>
        <p class="page-sub"><span class="badge-num">@Model.CaseId</span> Â· Assigned to @Model.AssignedOfficer</p>
    </div>
    <a asp-action="Index" class="btn-ghost"><i class="bi bi-arrow-left"></i> Back</a>
</div>

<div class="glass-card" style="margin-bottom:20px;">
    <h3>Complainant</h3>
    <div class="kv"><label>Name</label><div>@ViewBag.Complainant</div></div>
    <div class="kv"><label>CNIC</label><div><span class="badge-num">@ViewBag.ComplainantCNIC</span></div></div>
    <div class="kv"><label>Phone</label><div>@ViewBag.ComplainantPhone</div></div>
</div>

<div style="margin-bottom:20px;">
    <button onclick="window.print()" class="btn-primary-amber no-print" style="width:auto;padding:8px 24px;">
        <i class="bi bi-printer"></i> Print Case Report
    </button>
</div>

<div class="dash-grid">
    <div class="glass-card">
        <h3>Status Timeline</h3>
        @{
            var steps = new[] { "Open", "Under Investigation", "Pending Approval", "Closed" };
            var current = Model.Status switch {
                "Open" => 0,
                "Under Investigation" => 1,
                "Pending Approval" => 2,
                "Closed" => 3,
                _ => 0
            };
        }
        <div class="timeline">
            @for (int i = 0; i < steps.Length; i++)
            {
                <div class="timeline-step @(i <= current ? "done" : "") @(i == current ? "current" : "")">
                    <div class="ts-dot">@(i + 1)</div>
                    <div class="ts-label">@steps[i]</div>
                </div>
                @if (i < steps.Length - 1)
                {
                    <div class="timeline-line @(i < current ? "done" : "")"></div>
                }
            }
        </div>
    </div>

    <div class="glass-card">
        <h3>Case Details</h3>
        <div class="kv"><label>Priority</label><div>@Model.Priority</div></div>
        <div class="kv"><label>Status</label><div><span class="status-badge @Model.Status.ToLower().Replace(" ", "-")">@Model.Status</span></div></div>
        <div class="kv"><label>Date Opened</label><div>@Model.DateOpened.ToString("dd MMM yyyy HH:mm")</div></div>
        <div class="kv"><label>Last Updated</label><div>@Model.LastUpdated.ToString("dd MMM yyyy HH:mm")</div></div>
    </div>
</div>

@if (!string.IsNullOrEmpty(Model.InvestigationNotes))
{
    <div class="glass-card" style="margin-top:1.5rem">
        <h3><i class="bi bi-journal-text"></i> Investigation Notes</h3>
        <p style="white-space:pre-wrap; margin:0.75rem 0 0;">@Model.InvestigationNotes</p>
    </div>
}

@if (!string.IsNullOrEmpty(Model.ClosureReason))
{
    <div class="glass-card" style="margin-top:1rem">
        <h3><i class="bi bi-lock-fill"></i> Closure Reason</h3>
        <p style="white-space:pre-wrap; margin:0.75rem 0 0;">@Model.ClosureReason</p>
    </div>
}

@{
    var sessionRole = Context.Session.GetString("OfficerRole");
    var sessionName = Context.Session.GetString("OfficerName");
    var canUpdate = sessionRole == "Admin" || Model.AssignedOfficer == sessionName;
}

@if (canUpdate && Model.Status != "Closed")
{
    <div class="glass-card" style="margin-top:1rem">
        <h3><i class="bi bi-pencil-square"></i> Update Case</h3>
        <form method="post" asp-action="UpdateStatus" asp-route-id="@Model.CaseId" style="margin-top:1rem">
            @Html.AntiForgeryToken()
            <div class="mb-3">
                <label class="form-label">Update Status</label>
                <select name="status" class="form-control-warm" style="width:100%;padding:.5rem .75rem;margin-bottom:1rem">
                    @if (sessionRole == "Admin")
                    {
                        <option value="Open">Open</option>
                        <option value="Under Investigation">Under Investigation</option>
                        <option value="Pending Approval">Pending Approval</option>
                        <option value="Closed">Closed</option>
                    }
                    else
                    {
                        <option value="Under Investigation">Under Investigation</option>
                        <option value="Pending Approval">Submit for Closure Approval</option>
                    }
                </select>
            </div>
            <div class="mb-3">
                <label class="form-label">Notes / Findings</label>
                <textarea name="notes" class="form-control-warm" rows="3"
                    placeholder="Add investigation notes or closure reason..."
                    style="width:100%;padding:.5rem .75rem;resize:vertical;margin-bottom:1rem"></textarea>
            </div>
            <button type="submit" class="btn-primary-amber"><i class="bi bi-check2"></i> Update Case</button>
        </form>
    </div>
}

@if (sessionRole == "Admin" && Model.Status != "Closed")
{
    var officersList = ViewBag.Officers as List<SentinelPulse.Models.OfficerModel> ?? new List<SentinelPulse.Models.OfficerModel>();
    <div class="glass-card" style="margin-top:1rem">
        <h3><i class="bi bi-arrow-left-right"></i> Transfer Case</h3>
        <form method="post" asp-action="TransferCase" asp-route-id="@Model.CaseId"
              style="margin-top:1rem;display:flex;gap:1rem;align-items:flex-end;flex-wrap:wrap;">
            @Html.AntiForgeryToken()
            <div class="form-group" style="flex:1;min-width:200px;">
                <label>Reassign to Officer</label>
                <select name="newOfficer" class="form-control-warm">
                    @foreach (var o in officersList)
                    {
                        <option value="@o.Name">@o.Name (@o.BadgeNumber)</option>
                    }
                </select>
            </div>
            <button type="submit" class="btn-primary-amber" style="width:auto;padding:.5rem 1.5rem;"
                    onclick="return confirm('Transfer this case?')">
                <i class="bi bi-arrow-left-right"></i> Transfer
            </button>
        </form>
    </div>
}

@{
    var evidenceList = ViewBag.Evidence as List<SentinelPulse.Models.EvidenceModel> ?? new List<SentinelPulse.Models.EvidenceModel>();
    var suspectList  = ViewBag.Suspects  as List<SentinelPulse.Models.SuspectModel>  ?? new List<SentinelPulse.Models.SuspectModel>();
}

<div class="glass-card" style="margin-top:1.5rem;">
    <div class="card-header-row">
        <h3><i class="bi bi-archive"></i> Evidence Locker</h3>
        <span class="badge-num">@evidenceList.Count items</span>
    </div>

    @if (evidenceList.Any())
    {
        <div class="table-responsive" style="margin-bottom:1.5rem;">
            <table class="data-table">
                <thead>
                    <tr><th>Type</th><th>Description</th><th>Collected By</th><th>Date</th>@if (sessionRole == "Admin") { <th></th> }</tr>
                </thead>
                <tbody>
                    @foreach (var ev in evidenceList)
                    {
                        <tr>
                            <td><span class="status-badge investigation">@ev.Type</span></td>
                            <td>@ev.Description</td>
                            <td>@ev.CollectedBy</td>
                            <td>@ev.CollectedDate.ToString("dd MMM yyyy HH:mm")</td>
                            @if (sessionRole == "Admin")
                            {
                                <td>
                                    <form asp-controller="Evidence" asp-action="Delete" method="post" style="display:inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@ev.Id" />
                                        <input type="hidden" name="caseId" value="@Model.CaseId" />
                                        <button type="submit" class="link-danger" onclick="return confirm('Delete this evidence item?')">
                                            <i class="bi bi-trash"></i> Delete
                                        </button>
                                    </form>
                                </td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <p style="color:var(--muted);margin:.75rem 0 1.5rem;">No evidence logged yet.</p>
    }

    @if (canUpdate)
    {
        <h4 style="font-size:.95rem;margin-bottom:.75rem;"><i class="bi bi-plus-circle"></i> Add Evidence</h4>
        <form method="post" asp-controller="Evidence" asp-action="Add">
            @Html.AntiForgeryToken()
            <input type="hidden" name="CaseId" value="@Model.CaseId" />
            <div class="form-row">
                <div class="form-group">
                    <label>Type</label>
                    <select name="Type" class="form-control-warm">
                        <option>Physical</option>
                        <option>Digital</option>
                        <option>Document</option>
                        <option>Forensic</option>
                        <option>Witness Statement</option>
                        <option>CCTV Footage</option>
                        <option>Other</option>
                    </select>
                </div>
                <div class="form-group">
                    <label>Description</label>
                    <textarea name="Description" class="form-control-warm" rows="2" required
                        placeholder="Describe the evidence item..."></textarea>
                </div>
            </div>
            <button type="submit" class="btn-primary-amber" style="width:auto;padding:.5rem 1.5rem;">
                <i class="bi bi-plus-lg"></i> Add Evidence
            </button>
        </form>
    }
</div>

@if (suspectList.Any())
{
    <div class="glass-card" style="margin-top:1.5rem;">
        <div class="card-header-row">
            <h3><i class="bi bi-person-exclamation"></i> Suspects</h3>
            <span class="badge-num">@suspectList.Count on record</span>
        </div>
        <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:1rem;margin-top:1rem;">
            @foreach (var s in suspectList)
            {
                <div class="glass-card" style="padding:1rem;">
                    @if (!string.IsNullOrEmpty(s.PhotoPath))
                    {
                        <img src="@s.PhotoPath" alt="Suspect photo"
                             style="width:100%;height:160px;object-fit:cover;border-radius:8px;margin-bottom:.75rem;" />
                    }
                    else
                    {
                        <div style="width:100%;height:80px;display:grid;place-items:center;background:var(--border);border-radius:8px;margin-bottom:.75rem;color:var(--muted);font-size:2rem;">
                            <i class="bi bi-person-fill"></i>
                        </div>
                    }
                    <div style="font-weight:700;font-size:1rem;">@s.Name</div>
                    @if (!string.IsNullOrEmpty(s.CNIC))
                    {
                        <div style="font-size:.8rem;color:var(--muted);margin:.2rem 0;"><span class="badge-num">@s.CNIC</span></div>
                    }
                    @if (!string.IsNullOrEmpty(s.Description))
                    {
                        <p style="font-size:.85rem;color:var(--muted);margin:.5rem 0 0;">@s.Description</p>
                    }
                    @if (!string.IsNullOrEmpty(s.FaceDetectionResult))
                    {
                        <div style="margin-top:.5rem;padding:.4rem .7rem;background:rgba(200,150,42,0.12);border-radius:6px;font-size:.78rem;color:var(--primary-2);">
                            <i class="bi bi-cpu"></i> @s.FaceDetectionResult
                        </div>
                    }
                </div>
            }
        </div>
    </div>
}

@if (canUpdate)
{
    <div class="glass-card" style="margin-top:1.5rem;">
        <h3><i class="bi bi-person-plus"></i> Add Suspect</h3>
        <form method="post" asp-controller="Suspects" asp-action="Add" style="margin-top:16px;">
            @Html.AntiForgeryToken()
            <input type="hidden" name="CaseId" value="@Model.CaseId" />
            <div class="form-row">
                <div class="form-group">
                    <label>Suspect Name</label>
                    <input type="text" name="Name" class="form-control-warm" required />
                </div>
                <div class="form-group">
                    <label>CNIC (optional)</label>
                    <input type="text" name="CNIC" class="form-control-warm" placeholder="00000-0000000-0" />
                </div>
            </div>
            <div class="form-group" style="margin-bottom:12px;">
                <label>Description</label>
                <textarea name="Description" class="form-control-warm" rows="2"></textarea>
            </div>
            <button type="submit" class="btn-primary-amber" style="width:auto;padding:8px 24px;">Add Suspect</button>
        </form>
    </div>
}

@section PrintArea {
<div class="print-only-report" id="printReport">
    <div style="font-family: 'Times New Roman', serif; color: #000; padding: 20px;">

        <!-- HEADER -->
        <table style="width:100%;border-collapse:collapse;margin-bottom:20px;">
            <tr>
                <td style="width:60%;vertical-align:top;">
                    <div style="font-size:22pt;font-weight:bold;margin:0;">SentinelPulse</div>
                    <div style="font-size:9pt;color:#444;margin-top:2px;">Law Enforcement Operations Portal</div>
                    <div style="font-size:9pt;color:#444;">Islamabad Police — Operations Division</div>
                </td>
                <td style="width:40%;text-align:right;vertical-align:top;">
                    <div style="font-size:11pt;font-weight:bold;border:2px solid #000;padding:6px 10px;display:inline-block;">OFFICIAL CASE REPORT</div>
                    <div style="font-size:9pt;margin-top:6px;">Printed: @DateTime.Now.ToString("dd MMM yyyy HH:mm")</div>
                    <div style="font-size:9pt;">Ref: @Model.CaseId</div>
                </td>
            </tr>
        </table>

        <div style="border-top:3px double #000;border-bottom:1px solid #000;text-align:center;padding:8px 0;margin-bottom:18px;">
            <div style="font-size:14pt;font-weight:bold;letter-spacing:2px;">CASE INVESTIGATION REPORT</div>
            <div style="font-size:9pt;font-style:italic;">Confidential — For Official Use Only</div>
        </div>

        <!-- CASE OVERVIEW -->
        <div style="font-size:11pt;font-weight:bold;background:#000;color:#fff;padding:4px 10px;margin-bottom:0;">SECTION 1 — CASE OVERVIEW</div>
        <table style="width:100%;border-collapse:collapse;margin-bottom:16px;font-size:10pt;">
            <tr>
                <td style="padding:8px 10px;border:1px solid #000;width:25%;background:#f5f5f5;font-weight:bold;">Case ID</td>
                <td style="padding:8px 10px;border:1px solid #000;width:25%;font-family:'Courier New',monospace;">@Model.CaseId</td>
                <td style="padding:8px 10px;border:1px solid #000;width:25%;background:#f5f5f5;font-weight:bold;">Priority</td>
                <td style="padding:8px 10px;border:1px solid #000;width:25%;">@Model.Priority</td>
            </tr>
            <tr>
                <td style="padding:8px 10px;border:1px solid #000;background:#f5f5f5;font-weight:bold;">Status</td>
                <td style="padding:8px 10px;border:1px solid #000;">@Model.Status</td>
                <td style="padding:8px 10px;border:1px solid #000;background:#f5f5f5;font-weight:bold;">Assigned Officer</td>
                <td style="padding:8px 10px;border:1px solid #000;">@Model.AssignedOfficer</td>
            </tr>
            <tr>
                <td style="padding:8px 10px;border:1px solid #000;background:#f5f5f5;font-weight:bold;">Date Opened</td>
                <td style="padding:8px 10px;border:1px solid #000;">@Model.DateOpened.ToString("dd MMM yyyy HH:mm")</td>
                <td style="padding:8px 10px;border:1px solid #000;background:#f5f5f5;font-weight:bold;">Last Updated</td>
                <td style="padding:8px 10px;border:1px solid #000;">@Model.LastUpdated.ToString("dd MMM yyyy HH:mm")</td>
            </tr>
            <tr>
                <td style="padding:8px 10px;border:1px solid #000;background:#f5f5f5;font-weight:bold;">Case Title</td>
                <td colspan="3" style="padding:8px 10px;border:1px solid #000;">@Model.Title</td>
            </tr>
        </table>

        @if (ViewBag.Complainant != null)
        {
            <div style="font-size:11pt;font-weight:bold;background:#000;color:#fff;padding:4px 10px;margin-bottom:0;">SECTION 2 — COMPLAINANT INFORMATION</div>
            <table style="width:100%;border-collapse:collapse;margin-bottom:16px;font-size:10pt;">
                <tr>
                    <td style="padding:8px 10px;border:1px solid #000;width:25%;background:#f5f5f5;font-weight:bold;">Name</td>
                    <td style="padding:8px 10px;border:1px solid #000;width:25%;">@ViewBag.Complainant</td>
                    <td style="padding:8px 10px;border:1px solid #000;width:25%;background:#f5f5f5;font-weight:bold;">CNIC</td>
                    <td style="padding:8px 10px;border:1px solid #000;width:25%;font-family:'Courier New',monospace;">@ViewBag.ComplainantCNIC</td>
                </tr>
                <tr>
                    <td style="padding:8px 10px;border:1px solid #000;background:#f5f5f5;font-weight:bold;">Phone</td>
                    <td colspan="3" style="padding:8px 10px;border:1px solid #000;">@ViewBag.ComplainantPhone</td>
                </tr>
            </table>
        }

        <div style="font-size:11pt;font-weight:bold;background:#000;color:#fff;padding:4px 10px;margin-bottom:0;">SECTION 3 — INVESTIGATION NOTES</div>
        <div style="border:1px solid #000;padding:12px;margin-bottom:16px;min-height:80px;font-size:10pt;line-height:1.6;white-space:pre-wrap;">@(string.IsNullOrEmpty(Model.InvestigationNotes) ? "No investigation notes recorded." : Model.InvestigationNotes)</div>

        @if (!string.IsNullOrEmpty(Model.ClosureReason))
        {
            <div style="font-size:11pt;font-weight:bold;background:#000;color:#fff;padding:4px 10px;margin-bottom:0;">SECTION 4 — CLOSURE REASON</div>
            <div style="border:1px solid #000;padding:12px;margin-bottom:16px;font-size:10pt;line-height:1.6;">@Model.ClosureReason</div>
        }

        @if (evidenceList.Any())
        {
            <div style="font-size:11pt;font-weight:bold;background:#000;color:#fff;padding:4px 10px;margin-bottom:0;">SECTION 5 — EVIDENCE LOG</div>
            <table style="width:100%;border-collapse:collapse;margin-bottom:16px;font-size:9.5pt;">
                <thead>
                    <tr style="background:#e5e5e5;">
                        <th style="padding:6px 8px;border:1px solid #000;text-align:left;">#</th>
                        <th style="padding:6px 8px;border:1px solid #000;text-align:left;">Type</th>
                        <th style="padding:6px 8px;border:1px solid #000;text-align:left;">Description</th>
                        <th style="padding:6px 8px;border:1px solid #000;text-align:left;">Collected By</th>
                        <th style="padding:6px 8px;border:1px solid #000;text-align:left;">Date</th>
                    </tr>
                </thead>
                <tbody>
                    @{ int evIdx = 1; }
                    @foreach (var e in evidenceList)
                    {
                        <tr>
                            <td style="padding:6px 8px;border:1px solid #000;">@(evIdx++)</td>
                            <td style="padding:6px 8px;border:1px solid #000;">@e.Type</td>
                            <td style="padding:6px 8px;border:1px solid #000;">@e.Description</td>
                            <td style="padding:6px 8px;border:1px solid #000;">@e.CollectedBy</td>
                            <td style="padding:6px 8px;border:1px solid #000;">@e.CollectedDate.ToString("dd MMM yyyy")</td>
                        </tr>
                    }
                </tbody>
            </table>
        }

        @if (suspectList.Any())
        {
            <div style="font-size:11pt;font-weight:bold;background:#000;color:#fff;padding:4px 10px;margin-bottom:0;">SECTION 6 — SUSPECTS</div>
            <table style="width:100%;border-collapse:collapse;margin-bottom:16px;font-size:9.5pt;">
                <thead>
                    <tr style="background:#e5e5e5;">
                        <th style="padding:6px 8px;border:1px solid #000;text-align:left;">#</th>
                        <th style="padding:6px 8px;border:1px solid #000;text-align:left;">Name</th>
                        <th style="padding:6px 8px;border:1px solid #000;text-align:left;">CNIC</th>
                        <th style="padding:6px 8px;border:1px solid #000;text-align:left;">Description</th>
                        <th style="padding:6px 8px;border:1px solid #000;text-align:left;">Added</th>
                    </tr>
                </thead>
                <tbody>
                    @{ int spIdx = 1; }
                    @foreach (var s in suspectList)
                    {
                        <tr>
                            <td style="padding:6px 8px;border:1px solid #000;">@(spIdx++)</td>
                            <td style="padding:6px 8px;border:1px solid #000;">@s.Name</td>
                            <td style="padding:6px 8px;border:1px solid #000;font-family:'Courier New',monospace;">@(s.CNIC ?? "—")</td>
                            <td style="padding:6px 8px;border:1px solid #000;">@s.Description</td>
                            <td style="padding:6px 8px;border:1px solid #000;">@s.AddedDate.ToString("dd MMM yyyy")</td>
                        </tr>
                    }
                </tbody>
            </table>
        }

        <table style="width:100%;margin-top:50px;border-collapse:collapse;">
            <tr>
                <td style="width:45%;text-align:center;font-size:10pt;">
                    <div style="border-top:1px solid #000;padding-top:6px;width:80%;margin:0 auto;">
                        Investigating Officer
                    </div>
                </td>
                <td style="width:10%;"></td>
                <td style="width:45%;text-align:center;font-size:10pt;">
                    <div style="border-top:1px solid #000;padding-top:6px;width:80%;margin:0 auto;">
                        DSP — Signature & Official Stamp
                    </div>
                </td>
            </tr>
        </table>

        <div style="text-align:center;margin-top:40px;padding-top:8px;border-top:1px solid #999;font-size:8pt;color:#666;">
            This is a system-generated document from SentinelPulse Law Enforcement Operations Portal.<br>
            Document classified as CONFIDENTIAL. Unauthorized distribution is prohibited.
        </div>
    </div>
</div>

<style>
    /* Hide print report on screen */
    .print-only-report { display: none; }

    @@media print {
        /* Hide everything */
        body > * { display: none !important; }

        /* Show only the print report */
        body > .print-only-report,
        .print-only-report {
            display: block !important;
            position: static !important;
            width: 100% !important;
            background: white !important;
            color: #000 !important;
            font-family: 'Times New Roman', serif !important;
        }

        .print-only-report * {
            color: #000 !important;
            -webkit-print-color-adjust: exact !important;
            print-color-adjust: exact !important;
            visibility: visible !important;
        }

        /* Force backgrounds */
        .print-only-report [style*="background:#000"] {
            background: #000 !important;
            color: #fff !important;
        }
        .print-only-report [style*="background:#000"] * { color: #fff !important; }
        .print-only-report [style*="background:#f5f5f5"] { background: #f5f5f5 !important; }
        .print-only-report [style*="background:#e5e5e5"] { background: #e5e5e5 !important; }

        @@page { margin: 1.2cm; size: A4; }
    }
</style>
}

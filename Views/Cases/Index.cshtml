@model PaginatedList<SentinelPulse.Models.CaseModel>
@{
    ViewData["Title"] = "Cases";
    var role = Context.Session.GetString("OfficerRole");
    var currentView = ViewBag.CurrentView as string ?? "active";
    var pendingCases = currentView == "active" ? Model.Where(c => c.Status == "Pending Approval").ToList() : new List<SentinelPulse.Models.CaseModel>();
}

<div class="page-header">
    <div>
        <h1 class="page-title">Case Registry</h1>
        <p class="page-sub">@(role == "Admin" ? "All cases" : "Assigned to you")</p>
    </div>
</div>

<div id="list-section">
    <div style="margin-bottom: 1.5rem; display: flex; gap: 0.5rem;">
        <a href="?view=active#list-section" class="btn-ghost" style="@(currentView == "active" ? "background: var(--amber-soft); color: var(--amber); border: 1px solid var(--amber);" : "")">Active Cases</a>
        <a href="?view=archived#list-section" class="btn-ghost" style="@(currentView == "archived" ? "background: var(--amber-soft); color: var(--amber); border: 1px solid var(--amber);" : "")">Archived Cases</a>
    </div>

@if (role == "Admin" && pendingCases.Any())
{
    <div id="pending-approval" class="glass-card" style="margin-bottom:1.5rem; border-left: 3px solid var(--amber);">
        <div class="card-header-row">
            <h3><i class="bi bi-hourglass-split" style="color:var(--amber)"></i> Pending Closure Approval</h3>
            <span class="badge-num">@pendingCases.Count pending</span>
        </div>
        <div class="table-responsive">
            <table class="data-table">
                <thead>
                    <tr><th>Case ID</th><th>Title</th><th>Officer</th><th>Last Updated</th><th>Actions</th></tr>
                </thead>
                <tbody>
                    @foreach (var c in pendingCases)
                    {
                        <tr>
                            <td><a asp-controller="Cases" asp-action="Details" asp-route-id="@c.CaseId" style="text-decoration:none;"><span class="badge-num">@c.CaseId</span></a></td>
                            <td><a asp-controller="Cases" asp-action="Details" asp-route-id="@c.CaseId" style="color:var(--text);font-weight:500;text-decoration:underline;">@c.Title</a></td>
                            <td>@c.AssignedOfficer</td>
                            <td>@c.LastUpdated.ToString("dd MMM HH:mm")</td>
                            <td onclick="event.stopPropagation()">
                                <form asp-controller="Cases" asp-action="UpdateStatus" asp-route-id="@c.CaseId" method="post" style="display:inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="status" value="Closed" />
                                    <button type="submit" class="btn-primary-amber" style="padding:.25rem .75rem;font-size:.8rem">
                                        <i class="bi bi-check2"></i> Approve
                                    </button>
                                </form>
                                <form asp-controller="Cases" asp-action="UpdateStatus" asp-route-id="@c.CaseId" method="post" style="display:inline;margin-left:.5rem">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="status" value="Under Investigation" />
                                    <button type="submit" class="btn-ghost" style="padding:.25rem .75rem;font-size:.8rem">
                                        <i class="bi bi-x"></i> Reject
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

<div class="glass-card">
    <form onsubmit="window.location.hash='list-section'; return false;">
        <div class="filter-bar">
            <div class="search-wrap">
                <i class="bi bi-search"></i>
                <input id="case-search" placeholder="Search by Case ID, officer, status..." />
            </div>
            <select id="status-filter" class="form-control-warm" style="max-width:200px">
                <option value="">All Status</option>
                <option>Open</option>
                <option>Under Investigation</option>
                <option>Pending Approval</option>
                <option>Closed</option>
            </select>
        </div>
    </form>

    <div class="table-responsive">
        <table class="data-table" id="cases-table">
            <thead>
                <tr>
                    <th>Case ID</th><th>Title</th><th>Complainant</th><th>Assigned Officer</th>
                    <th>Priority</th><th>Status</th><th>Last Updated</th><th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var c in Model)
                {
                    var dot = c.Priority switch { "High" => "dot-red", "Medium" => "dot-amber", _ => "dot-green" };
                    <tr class="case-row" data-case='@System.Text.Json.JsonSerializer.Serialize(c)'>
                        <td><span class="badge-num">@c.CaseId</span></td>
                        <td>@c.Title</td>
                        @{
                            var complainants = ViewBag.Complainants as Dictionary<string, string>;
                            var complainant = complainants != null && complainants.ContainsKey(c.CaseId) ? complainants[c.CaseId] : "—";
                        }
                        <td>@complainant</td>
                        <td>@c.AssignedOfficer</td>
                        <td><span class="prio-dot @dot"></span> @c.Priority</td>
                        <td><span class="status-badge @c.Status.ToLower().Replace(" ", "-")">@c.Status</span></td>
                        <td>@c.LastUpdated.ToString("dd MMM HH:mm")</td>
                        <td onclick="event.stopPropagation()">
                            <a asp-action="Details" asp-route-id="@c.CaseId" class="link-amber">View</a>
                            @if (role == "Admin")
                            {
                                <form asp-action="Delete" asp-route-id="@c.CaseId" method="post" style="display:inline;margin-left:.5rem">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="link-danger" onclick="return confirm('Delete @c.CaseId?')">Delete</button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    
    @if (Model.TotalItems > 0)
    {
        <div style="margin-top: 1rem; display: flex; justify-content: space-between; align-items: center; color: var(--text-muted); font-size: 0.9rem;">
            <div>
                Showing @(((Model.PageIndex - 1) * 20) + 1) to @(Math.Min(Model.PageIndex * 20, Model.TotalItems)) of @Model.TotalItems
            </div>
            <div style="display: flex; gap: 0.5rem;">
                @if (Model.HasPreviousPage)
                {
                    <a href="?view=@currentView&pageNumber=@(Model.PageIndex - 1)#list-section" class="btn-ghost" style="padding: 0.25rem 0.5rem;">Prev</a>
                }
                @if (Model.HasNextPage)
                {
                    <a href="?view=@currentView&pageNumber=@(Model.PageIndex + 1)#list-section" class="btn-ghost" style="padding: 0.25rem 0.5rem;">Next</a>
                }
            </div>
        </div>
    }
    else
    {
        <div style="padding: 2rem; text-align: center; color: var(--text-muted);">
            No @currentView cases found.
        </div>
    }
</div>
</div>

<div class="modal-backdrop hidden" id="case-modal">
    <div class="glass-card modal-card">
        <div class="card-header-row">
            <h3 id="m-title">Case</h3>
            <button class="icon-btn" onclick="closeCaseModal()"><i class="bi bi-x-lg"></i></button>
        </div>
        <div id="m-body"></div>
    </div>
</div>

@section Scripts { <script>initCasesPage();</script> }
